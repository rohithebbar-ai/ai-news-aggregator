FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy dependency files first (layer caching)
COPY pyproject.toml .
COPY uv.lock* .

# Install dependencies
RUN uv sync --no-dev

# Copy source code
COPY . .

# Default: print help. Override with: docker run <image> ingest
ENTRYPOINT ["uv", "run", "python", "main.py"]
CMD []
