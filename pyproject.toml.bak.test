[project]
name = "ai-news-aggregator"
version = "0.1.0"
description = "AI Trend Intelligence Engine - ingestion, embedding, and LLM pipeline"
readme = "README.md"
requires-python = ">=3.11,<3.13"
dependencies = [
    "feedparser>=6.0.12",
    "groq>=1.0.0",
    "httpx>=0.28.1",
    "pgvector>=0.4.2",
    "psycopg2-binary>=2.9.11",
    "beautifulsoup4>=4.12.0",
    "pydantic>=2.0.0",
    "python-dotenv>=1.2.1",
    # Pinned for macOS / Intel compatibility (same as hr-agent)
    "torch>=2.2.0,<2.3.0",
    "numpy>=1.24.0,<2.0.0",
    "sentence-transformers>=3.0.0,<4.0.0",
    "transformers>=4.44.0,<4.50.0",
    "sqlalchemy>=2.0.0",
    "youtube-transcript-api>=0.6.0",
    "fastmcp>=2.0.0",
    "langgraph>=0.2.0",
    "langchain-openai>=0.2.0",
    "langchain-core>=0.3.0",
    "boto3>=1.34.0",
    "jsonschema>=4.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0.0",
    "ruff>=0.8.0",
    "mypy>=1.11.0",
]

[tool.mypy]
python_version = "3.11"
ignore_missing_imports = true

[tool.uv]
constraint-dependencies = [
    "onnxruntime<1.20.0",
]
